# Copy this file to .env and fill in your key.
# The server reads this via the environment — never hardcode it in source.
#
# Get a key at: https://console.anthropic.com/
# Required only for POST /api/analyze-resume (résumé upload feature).

ANTHROPIC_API_KEY=sk-ant-...

# Optional: speeds up email discovery (GET /api/professor/:id/email).
# Raises the NCBI E-utilities rate limit from 3 to 10 requests/sec.
# Get one (free) at: https://www.ncbi.nlm.nih.gov/account/settings/
# NCBI_API_KEY=...
