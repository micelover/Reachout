# Copy this file to .env and fill in your key.
# The server reads this via the environment — never hardcode it in source.
#
# Get a key at: https://console.anthropic.com/
# Required only for POST /api/analyze-resume (résumé upload feature).

ANTHROPIC_API_KEY=sk-ant-...

# Real contact email — sent to OpenAlex (polite pool), NCBI, Unpaywall (which
# REQUIRES a real address), and Europe PMC. Used by the email-discovery engine
# (GET /api/professor/:id/email). Defaults to gladwyn504@gmail.com if unset.
CONTACT_EMAIL=gladwyn504@gmail.com

# Optional: durable, redeploy-surviving cache for email discovery (Firestore).
# Base64-encoded service-account JSON. UNSET ⇒ in-memory Map cache (no persistence,
# the default — fine for local dev and tests). As an alternative to this, you may
# instead set GOOGLE_APPLICATION_CREDENTIALS to a service-account JSON file path.
# FIREBASE_SERVICE_ACCOUNT=

# Optional: speeds up email discovery (GET /api/professor/:id/email).
# Raises the NCBI E-utilities rate limit from 3 to 10 requests/sec.
# Get one (free) at: https://www.ncbi.nlm.nih.gov/account/settings/
# NCBI_API_KEY=...

# Optional but recommended: OpenAlex API key. Moves all OpenAlex calls off the
# per-IP anonymous demo budget onto the key's $1/day free allowance (plus any
# prepaid/premium budget). Without it you'll hit HTTP 429 quickly.
# Get one (free) at: https://openalex.org/ (request an API key)
# OPENALEX_API_KEY=...

# CORS allowlist. Comma-separated list of EXACT production origins that may call
# the API from a browser (scheme + host + optional port, no trailing slash), e.g.
#   CORS_ALLOWED_ORIGINS=https://reachout.app,https://www.reachout.app
# Dev origins are ALWAYS allowed regardless of this value: any http(s)://localhost
# or http(s)://127.0.0.1 (any port), and file:// pages (Origin header "null").
# Requests with no Origin header (curl / server-to-server) are never blocked.
# CORS_ALLOWED_ORIGINS=
